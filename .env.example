# SecureVault – Environment Variables
# Copy this file to .env and fill in your values

# Gmail SMTP (use App Password, not your regular password)
# To create an App Password: Google Account → Security → 2-Step Verification → App Passwords
SENDER_EMAIL=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
RECEIVER_EMAIL=destination@gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
